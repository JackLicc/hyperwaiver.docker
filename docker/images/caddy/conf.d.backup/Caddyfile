hyperwaiver.com {
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}

    tls {
        dns cloudflare {env.CF_API_TOKEN}
        resolvers 1.1.1.1
    }

    redir https://www.{host}{uri}
}

www.hyperwaiver.com {
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}

    import ./security.conf
    
    tls {
        dns cloudflare {env.CF_API_TOKEN}
        resolvers 1.1.1.1
    }

    handle {
        reverse_proxy host.docker.internal:3100
    }
}

http://*.hyperwaiver.com {
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}

    import ./security.conf

    @apiPath {
        path /api/*
    }

    handle @apiPath {
	root * /var/www/hyperwaiver/public

	file_server

	rewrite * /index.php?{query}

	php_fastcgi php-fpm:9000
    }

    @pdfServerPath {
        path /puppeteer/generate/pdf
    }

    handle @pdfServerPath {
        # puppeteer server
        reverse_proxy host.docker.internal:3300
    }

    @pdfPagePath {
	path /app/waiver/pdfview/*
    }

    handle @pdfPagePath {
        reverse_proxy host.docker.internal:3000
    }

    handle {
        redir https://{host}{uri}
    }
}

https://*.hyperwaiver.com {
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}
    
    import ./security.conf

    tls {
        dns cloudflare {env.CF_API_TOKEN}
        resolvers 1.1.1.1
    }

    @apiPath {
        path /api/*
    }

    handle @apiPath {
        root * /var/www/hyperwaiver/public

        file_server

        rewrite * /index.php?{query}

        php_fastcgi php-fpm:9000
    }

    @pdfServerPath {
        path /puppeteer/generate/pdf
    }

    handle @pdfServerPath {
        # puppeteer server
        reverse_proxy host.docker.internal:3300
    }

    handle {
        reverse_proxy host.docker.internal:3000
    }
}
