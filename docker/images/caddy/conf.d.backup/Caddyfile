hyperwaiver.com {
    redir https://www.{host}{uri}
}

http://*.hyperwaiver.com {
    @wwwHost {
        host www.hyperwaiver.com
    }

    handle @wwwHost {
        redir https://www.{host}{uri}
    }

    # make sure all api requests are internal calls
    @apiPath {
        path /api/*
    }

    handle @apiPath {
	root * /var/www/hyperwaiver/public

	file_server

	rewrite * /index.php?{query}

	php_fastcgi php-fpm:9000
    }

    @pdfServerPath {
        path /puppeteer/generate/pdf
    }

    handle @pdfServerPath {
        # puppeteer server
        reverse_proxy host.docker.internal:3300
    }

    @pdfPagePath {
	path /app/waiver/pdfview/*
    }

    handle @pdfPagePath {
        reverse_proxy host.docker.internal:3000
    }

    handle {
        redir https://{host}{uri}
    }
}

https://*.hyperwaiver.com {
    import ./security.conf

    tls {
        dns cloudflare {env.CF_API_TOKEN}
        resolvers 1.1.1.1
    }

    @wwwHost {
        host www.hyperwaiver.com
    }

    handle @wwwHost {
        reverse_proxy host.docker.internal:3100
    }

    @apiPath {
        path /api/*
    }

    handle @apiPath {
        root * /var/www/hyperwaiver/public

        file_server

        rewrite * /index.php?{query}

        php_fastcgi php-fpm:9000
    }

    @pdfServerPath {
        path /puppeteer/generate/pdf
    }

    handle @pdfServerPath {
        # puppeteer server
        reverse_proxy host.docker.internal:3300
    }

    handle {
        reverse_proxy host.docker.internal:3000
    }
}
