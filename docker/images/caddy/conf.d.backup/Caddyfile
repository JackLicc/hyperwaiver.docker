http://central.hpwaiver.com,
http://tenant1.hpwaiver.com,
http://tenant2.hpwaiver.com,
http://tenant3.hpwaiver.com,
http://tenant4.hpwaiver.com,
http://tenant5.hpwaiver.com,
http://tenant6.hpwaiver.com,
http://tenant7.hpwaiver.com,
http://tenant8.hpwaiver.com {
    # make sure all api requests are internal calls
    @apiPath {
        path /api/*
    }

    handle @apiPath {
		root * /var/www/hyperwaiver/public

		file_server

		rewrite * /index.php?{query}

		php_fastcgi php-fpm:9000
    }

    @pdfServerPath {
        path /puppeteer/generate/pdf
    }

    handle @pdfServerPath {
        # puppeteer server
        reverse_proxy host.docker.internal:3300
    }

    @pdfPagePath {
	path /app/waiver/pdfview/*
    }

    handle @pdfPagePath {
        reverse_proxy host.docker.internal:3000
    }

    handle {
        redir https://{host}{uri}
    }
}

